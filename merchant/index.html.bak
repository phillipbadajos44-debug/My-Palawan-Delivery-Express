<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>PDE – Merchant</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{--gd:#1e3a5f;--gm:#2563eb;--gl:#dbeafe;--bg:#f0f6ff;--gold:#f59e0b;--red:#ef4444;--green:#22c55e;--text:#1e293b;--muted:#6b7280;--card:#fff;--r:16px;--sh:0 4px 24px rgba(37,99,235,.10);--nav:68px;}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}
/* AUTH */
.auth-screen{display:flex;flex-direction:column;min-height:100vh;}
.auth-hero{background:linear-gradient(135deg,var(--gd),var(--gm));padding:50px 24px 44px;text-align:center;}
.auth-hero-icon{font-size:60px;margin-bottom:14px;}
.auth-hero h1{color:#fff;font-size:24px;font-weight:900;}
.auth-hero p{color:var(--gl);font-size:13px;margin-top:6px;opacity:.9;}
.auth-body{background:#fff;border-radius:28px 28px 0 0;margin-top:-20px;padding:28px 24px 40px;flex:1;overflow-y:auto;}
.auth-tabs{display:flex;gap:0;background:#f3f4f6;border-radius:14px;padding:4px;margin-bottom:22px;}
.auth-tab{flex:1;padding:10px;text-align:center;font-size:14px;font-weight:700;color:var(--muted);border-radius:10px;cursor:pointer;transition:all .2s;}
.auth-tab.active{background:#fff;color:var(--gd);box-shadow:0 2px 8px rgba(0,0,0,.08);}
.auth-form{display:none;}.auth-form.active{display:block;}
.field{margin-bottom:14px;}
.field label{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;display:block;margin-bottom:5px;}
.field input,.field select,.field textarea{width:100%;padding:12px 14px;border:1.5px solid #e5e7eb;border-radius:12px;font-size:14px;font-family:inherit;outline:none;transition:border-color .2s;background:#fff;}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--gm);}
.field textarea{resize:none;height:72px;}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.auth-btn{width:100%;padding:15px;background:linear-gradient(135deg,var(--gd),var(--gm));color:#fff;border:none;border-radius:14px;font-size:15px;font-weight:800;cursor:pointer;margin-top:6px;}
.auth-error{background:#fee2e2;color:#991b1b;padding:12px 14px;border-radius:12px;font-size:13px;font-weight:600;margin-bottom:14px;display:none;}
.auth-error.show{display:block;}
.auth-success{background:#d1fae5;color:#065f46;padding:12px 14px;border-radius:12px;font-size:13px;font-weight:600;margin-bottom:14px;display:none;}
.auth-success.show{display:block;}
.pw-wrap{position:relative;}
.pw-wrap input{padding-right:44px;}
.pw-eye{position:absolute;right:14px;top:50%;transform:translateY(-50%);font-size:18px;cursor:pointer;color:var(--muted);}
.sec-div{font-size:12px;font-weight:800;color:var(--gm);text-transform:uppercase;letter-spacing:.6px;margin:16px 0 10px;padding-bottom:6px;border-bottom:2px solid var(--gl);}
.upload-box{border:2px dashed #d1d5db;border-radius:12px;padding:18px;text-align:center;cursor:pointer;position:relative;overflow:hidden;transition:border-color .2s;}
.upload-box:hover{border-color:var(--gm);}
.upload-box input{position:absolute;inset:0;opacity:0;cursor:pointer;}
.upload-preview{font-size:12px;color:var(--gm);margin-top:4px;font-weight:700;}
/* PENDING */
.pending-screen{display:none;min-height:100vh;background:var(--bg);flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:40px 24px;}
.pending-screen.active{display:flex;}
.pending-icon{font-size:80px;margin-bottom:20px;}
.pending-title{font-size:24px;font-weight:900;color:var(--gd);margin-bottom:8px;}
.pending-sub{font-size:14px;color:var(--muted);line-height:1.7;max-width:300px;}
.pending-badge{background:var(--gl);color:var(--gm);font-size:13px;font-weight:700;padding:8px 20px;border-radius:20px;margin-top:16px;display:inline-block;}
.logout-link{margin-top:20px;font-size:13px;color:var(--muted);cursor:pointer;text-decoration:underline;}
/* APP */
.app{display:none;}
.app.active{display:block;padding-bottom:var(--nav);}
.header{background:linear-gradient(135deg,var(--gd),var(--gm));padding:18px 18px 20px;position:sticky;top:0;z-index:100;box-shadow:0 2px 16px rgba(37,99,235,.25);}
.header-top{display:flex;align-items:center;justify-content:space-between;}
.brand{display:flex;align-items:center;gap:10px;}
.brand-icon{width:40px;height:40px;background:rgba(255,255,255,.18);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px;}
.brand-name{color:#fff;font-size:15px;font-weight:800;line-height:1.2;}
.brand-sub{color:var(--gl);font-size:10px;font-weight:500;margin-top:1px;opacity:.85;}
.store-toggle{display:flex;align-items:center;gap:6px;}
.toggle-lbl{color:rgba(255,255,255,.85);font-size:11px;font-weight:700;}
.toggle{width:42px;height:22px;background:rgba(255,255,255,.3);border-radius:20px;position:relative;cursor:pointer;transition:background .2s;}
.toggle.on{background:var(--green);}
.toggle::after{content:'';position:absolute;top:2px;left:2px;width:18px;height:18px;background:#fff;border-radius:50%;transition:transform .2s;}
.toggle.on::after{transform:translateX(20px);}
.page{display:none;}.page.active{display:block;}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}
.section-title{font-size:20px;font-weight:800;color:var(--gd);padding:18px 18px 10px;}
/* STATS */
.stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;padding:0 18px 16px;}
.stat-card{background:var(--card);border-radius:16px;box-shadow:var(--sh);padding:16px;animation:fadeUp .3s ease both;position:relative;overflow:hidden;}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--gm);}
.stat-card.green::before{background:var(--green);}
.stat-card.gold::before{background:var(--gold);}
.stat-card.red::before{background:var(--red);}
.stat-val{font-size:26px;font-weight:900;color:var(--gm);}
.stat-card.green .stat-val{color:var(--green);}
.stat-card.gold .stat-val{color:var(--gold);}
.stat-card.red .stat-val{color:var(--red);}
.stat-label{font-size:12px;color:var(--muted);font-weight:600;margin-top:4px;}
.stat-icon{font-size:24px;margin-bottom:6px;}
/* FILTER TABS */
.filter-tabs{display:flex;gap:8px;padding:0 18px 12px;overflow-x:auto;scrollbar-width:none;}
.filter-tabs::-webkit-scrollbar{display:none;}
.ftab{flex-shrink:0;padding:7px 16px;border-radius:20px;border:1.5px solid var(--gl);background:#fff;font-size:13px;font-weight:600;color:var(--muted);cursor:pointer;transition:all .15s;}
.ftab.active{background:var(--gm);color:#fff;border-color:var(--gm);}
/* ORDER CARDS */
.orders-wrap{padding:0 18px 16px;}
.order-card{background:var(--card);border-radius:16px;box-shadow:var(--sh);padding:16px;margin-bottom:14px;animation:fadeUp .3s ease both;}
.order-hdr{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;}
.order-id{font-size:12px;color:var(--muted);font-weight:600;}
.order-time{font-size:11px;color:var(--muted);}
.o-status{font-size:11px;font-weight:800;padding:3px 10px;border-radius:20px;}
.s-new{background:#fee2e2;color:#991b1b;}.s-acc{background:#d1fae5;color:#065f46;}.s-rdy{background:#dbeafe;color:#1e40af;}.s-done{background:#e9d5ff;color:#6b21a8;}.s-rej{background:#f3f4f6;color:var(--muted);}
.order-customer{font-size:14px;font-weight:700;margin-bottom:4px;}
.order-addr{font-size:12px;color:var(--muted);margin-bottom:8px;}
.order-items-list{font-size:13px;margin-bottom:10px;line-height:1.7;}
.order-pay{font-size:12px;color:var(--muted);margin-bottom:8px;}
.order-total{font-size:17px;font-weight:900;color:var(--gm);margin-bottom:12px;}
.order-actions{display:flex;gap:8px;flex-wrap:wrap;}
.btn-accept{flex:1;min-width:80px;padding:11px;background:var(--gm);color:#fff;border:none;border-radius:12px;font-size:13px;font-weight:700;cursor:pointer;transition:background .15s;}
.btn-accept:hover{background:var(--gd);}
.btn-ready{flex:1;min-width:80px;padding:11px;background:#8b5cf6;color:#fff;border:none;border-radius:12px;font-size:13px;font-weight:700;cursor:pointer;}
.btn-reject{flex:1;min-width:80px;padding:11px;background:#fee2e2;color:#991b1b;border:none;border-radius:12px;font-size:13px;font-weight:700;cursor:pointer;}
.btn-off{background:var(--muted)!important;pointer-events:none;}
/* PRODUCT FORM */
.add-form{background:var(--card);border-radius:20px;margin:0 18px 20px;box-shadow:var(--sh);padding:20px;}
.add-form h3{font-size:15px;font-weight:800;margin-bottom:14px;color:var(--gd);}
.submit-btn{width:100%;padding:14px;background:linear-gradient(135deg,var(--gd),var(--gm));color:#fff;border:none;border-radius:14px;font-size:15px;font-weight:800;cursor:pointer;margin-top:4px;}
/* PRODUCT LIST */
.prod-list{padding:0 18px 16px;}
.prod-item{background:var(--card);border-radius:14px;box-shadow:var(--sh);padding:14px;margin-bottom:12px;animation:fadeUp .3s ease both;}
.prod-item-top{display:flex;align-items:center;gap:12px;}
.prod-img{width:56px;height:56px;border-radius:12px;background:var(--bg);display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0;overflow:hidden;}
.prod-img img{width:100%;height:100%;object-fit:cover;}
.prod-info{flex:1;}
.prod-name{font-size:14px;font-weight:700;}
.prod-price{font-size:15px;font-weight:900;color:var(--gm);}
.prod-cat{font-size:11px;color:var(--muted);margin-top:2px;}
.prod-actions{display:flex;gap:8px;margin-top:10px;}
.prod-btn{flex:1;padding:8px;border:none;border-radius:10px;font-size:12px;font-weight:700;cursor:pointer;}
.btn-edit-prod{background:var(--gl);color:var(--gm);}
.btn-del-prod{background:#fee2e2;color:var(--red);}
.btn-toggle-stock{background:#f0fdf4;color:var(--green);}
/* STOCK BADGE */
.stock-badge{display:inline-block;padding:2px 8px;border-radius:20px;font-size:11px;font-weight:700;margin-top:4px;}
.stock-ok{background:#d1fae5;color:#065f46;}
.stock-low{background:#fef3c7;color:#92400e;}
.stock-out{background:#fee2e2;color:var(--red);}
/* SALES CHART */
.sales-card{background:var(--card);border-radius:20px;margin:0 18px 16px;box-shadow:var(--sh);padding:20px;}
.sales-card h3{font-size:15px;font-weight:800;color:var(--gd);margin-bottom:16px;}
.chart-bars{display:flex;align-items:flex-end;gap:6px;height:100px;}
.bar-wrap{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;}
.bar{width:100%;background:var(--gl);border-radius:6px 6px 0 0;transition:height .4s;position:relative;}
.bar.highlight{background:var(--gm);}
.bar-val{font-size:9px;color:var(--muted);font-weight:700;}
.bar-day{font-size:9px;color:var(--muted);}
/* EARN CARD */
.earn-card{background:linear-gradient(135deg,var(--gd),var(--gm));border-radius:20px;margin:0 18px 16px;padding:24px 20px;color:#fff;}
.earn-total{font-size:34px;font-weight:900;letter-spacing:-1px;}
.earn-label{font-size:12px;opacity:.8;margin-top:4px;}
.earn-breakdown{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-top:16px;}
.earn-item{background:rgba(255,255,255,.15);border-radius:12px;padding:10px;text-align:center;}
.earn-val{font-size:17px;font-weight:800;}
.earn-lbl{font-size:10px;opacity:.8;margin-top:2px;}
/* PROFILE */
.profile-hero{background:linear-gradient(135deg,var(--gd),var(--gm));padding:28px 18px 44px;text-align:center;}
.store-avatar{width:80px;height:80px;border-radius:20px;background:rgba(255,255,255,.2);border:3px solid rgba(255,255,255,.4);display:flex;align-items:center;justify-content:center;font-size:36px;margin:0 auto 12px;overflow:hidden;cursor:pointer;}
.store-avatar img{width:100%;height:100%;object-fit:cover;}
.store-name-display{color:#fff;font-size:20px;font-weight:800;}
.store-sub{color:var(--gl);font-size:12px;margin-top:4px;opacity:.85;}
.profile-card{background:#fff;border-radius:20px;margin:-22px 16px 0;box-shadow:0 8px 32px rgba(37,99,235,.15);padding:20px;position:relative;z-index:1;}
.pf{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid var(--bg);}
.pf:last-child{border-bottom:none;}
.pf-icon{width:38px;height:38px;background:var(--bg);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.pf-info{flex:1;}
.pf-label{font-size:11px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:.5px;}
.pf-value{font-size:14px;font-weight:700;margin-top:2px;}
.pf-edit{font-size:18px;color:var(--muted);cursor:pointer;padding:4px;}
.sec-title{font-size:13px;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:.6px;padding:18px 18px 8px;}
.menu-item{display:flex;align-items:center;gap:12px;padding:14px 18px;background:#fff;border-bottom:1px solid var(--bg);cursor:pointer;}
.menu-item:hover{background:#f9fafb;}
.mi-icon{font-size:20px;width:36px;text-align:center;}
.mi-label{font-size:14px;font-weight:600;flex:1;}
.mi-arr{color:var(--muted);}
/* MODAL */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:400;align-items:flex-end;}
.modal-bg.open{display:flex;}
.modal-sheet{background:#fff;border-radius:24px 24px 0 0;padding:22px 18px 36px;width:100%;max-height:90vh;overflow-y:auto;}
.modal-handle{width:40px;height:4px;background:#e5e7eb;border-radius:4px;margin:0 auto 18px;}
.modal-title{font-size:18px;font-weight:800;margin-bottom:18px;}
.modal-btn{width:100%;padding:14px;background:linear-gradient(135deg,var(--gd),var(--gm));color:#fff;border:none;border-radius:14px;font-size:15px;font-weight:800;cursor:pointer;margin-top:8px;}
/* NOTIF */
.side-panel{display:none;position:fixed;top:0;right:0;bottom:0;width:min(340px,100vw);background:#fff;z-index:350;box-shadow:-4px 0 32px rgba(0,0,0,.15);overflow-y:auto;}
.side-panel.open{display:block;}
.sp-header{background:linear-gradient(135deg,var(--gd),var(--gm));padding:20px 18px;color:#fff;display:flex;align-items:center;justify-content:space-between;}
.sp-header h3{font-size:18px;font-weight:800;}
.sp-close{font-size:22px;cursor:pointer;opacity:.8;}
.notif-item{padding:14px 18px;border-bottom:1px solid var(--bg);display:flex;gap:10px;cursor:pointer;}
.notif-item.unread{background:var(--bg);}
.ni-text{font-size:13px;font-weight:600;}
.ni-sub{font-size:12px;color:var(--muted);margin-top:2px;}
.ni-time{font-size:11px;color:var(--muted);margin-top:2px;}
/* NAV */
.bottom-nav{position:fixed;bottom:0;left:0;right:0;height:var(--nav);background:#fff;border-top:1px solid #e5e7eb;display:flex;align-items:center;justify-content:space-around;z-index:150;box-shadow:0 -4px 20px rgba(37,99,235,.08);}
.nav-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;padding:6px 0;cursor:pointer;position:relative;color:var(--muted);border:none;background:none;font-family:inherit;}
.nav-item.active{color:var(--gm);}
.nav-item.active .nav-icon{background:var(--gl);border-radius:12px;}
.nav-icon{width:36px;height:30px;display:flex;align-items:center;justify-content:center;font-size:20px;}
.nav-label{font-size:10px;font-weight:600;}
.n-badge{position:absolute;top:3px;right:calc(50% - 22px);background:var(--red);color:#fff;font-size:9px;font-weight:800;width:17px;height:17px;border-radius:50%;display:none;align-items:center;justify-content:center;border:1.5px solid #fff;}
.toast{position:fixed;bottom:calc(var(--nav)+12px);left:50%;transform:translateX(-50%) translateY(80px);background:var(--gd);color:#fff;padding:12px 22px;border-radius:40px;font-size:14px;font-weight:600;z-index:500;display:flex;align-items:center;gap:8px;box-shadow:0 8px 24px rgba(37,99,235,.35);transition:transform .35s cubic-bezier(.32,.72,0,1),opacity .35s;opacity:0;white-space:nowrap;max-width:90vw;}
.toast.show{transform:translateX(-50%) translateY(0);opacity:1;}
.empty-state{text-align:center;padding:40px 24px;color:var(--muted);}
.empty-state .ei{font-size:48px;margin-bottom:10px;}
.spinner{width:36px;height:36px;border:3px solid var(--gl);border-top-color:var(--gm);border-radius:50%;animation:spin .7s linear infinite;margin:40px auto;display:block;}
@keyframes spin{to{transform:rotate(360deg);}}
.avatar-input{display:none;}
</style>
</head>
<body>

<!-- AUTH -->
<div class="auth-screen" id="authScreen">
  <div class="auth-hero">
    <div class="auth-hero-icon">🏪</div>
    <h1>Merchant Portal</h1>
    <p>Palawan Delivery Express</p>
  </div>
  <div class="auth-body">
    <div class="auth-tabs">
      <div class="auth-tab active" onclick="switchTab('login')">Log In</div>
      <div class="auth-tab" onclick="switchTab('apply')">Apply as Merchant</div>
    </div>
    <!-- LOGIN -->
    <div class="auth-form active" id="form-login">
      <div class="auth-error" id="login-err"></div>
      <div class="field"><label>Email</label><input id="l-email" type="email" placeholder="store@email.com"/></div>
      <div class="field"><label>Password</label>
        <div class="pw-wrap"><input id="l-pw" type="password" placeholder="Your password"/><span class="pw-eye" onclick="togglePw('l-pw',this)">👁️</span></div>
      </div>
      <button class="auth-btn" onclick="doLogin()">Log In</button>
    </div>
    <!-- APPLY -->
    <div class="auth-form" id="form-apply">
      <div class="auth-error" id="apply-err"></div>
      <div class="auth-success" id="apply-ok">✅ Application submitted! Waiting for Admin approval.</div>
      <div class="sec-div">👤 Personal Information</div>
      <div class="field"><label>Full Name *</label><input id="a-name" type="text" placeholder="Juan dela Cruz"/></div>
      <div class="field-row">
        <div class="field"><label>Phone *</label><input id="a-phone" type="tel" placeholder="09171234567"/></div>
        <div class="field"><label>Email *</label><input id="a-email" type="email" placeholder="juan@email.com"/></div>
      </div>
      <div class="field"><label>Password *</label>
        <div class="pw-wrap"><input id="a-pw" type="password" placeholder="Min 6 characters"/><span class="pw-eye" onclick="togglePw('a-pw',this)">👁️</span></div>
      </div>
      <div class="sec-div">🏪 Business Information</div>
      <div class="field"><label>Store / Business Name *</label><input id="a-store" type="text" placeholder="e.g. Juan's Sari-Sari Store"/></div>
      <div class="field"><label>Business Type *</label>
        <select id="a-btype"><option value="">Select type</option>
          <option>Sari-Sari Store</option><option>Grocery Store</option><option>Restaurant / Food Stall</option>
          <option>Meat Shop</option><option>Fish Market</option><option>Bakery</option>
          <option>Pharmacy / Drug Store</option><option>General Merchandise</option><option>Other</option>
        </select>
      </div>
      <div class="field"><label>Store Address *</label><input id="a-addr" type="text" placeholder="Street, Barangay, City"/></div>
      <div class="field"><label>Main Product Category *</label>
        <select id="a-pcat"><option value="">Select category</option>
          <option>Canned Goods</option><option>Rice & Grains</option><option>Meat & Poultry</option>
          <option>Fish & Seafood</option><option>Vegetables & Fruits</option><option>Dairy & Eggs</option>
          <option>Beverages</option><option>Bread & Bakery</option><option>Household Items</option>
          <option>Health & Beauty</option><option>Mixed / General</option>
        </select>
      </div>
      <div class="field"><label>Store Description</label><textarea id="a-desc" placeholder="Tell us about your store…"></textarea></div>
      <div class="sec-div">📋 Business Documents</div>
      <div class="field"><label>DTI / SEC Registration No. *</label><input id="a-dti" type="text" placeholder="DTI-2024-12345"/></div>
      <div class="field"><label>Business Permit No. *</label><input id="a-permit" type="text" placeholder="BP-2024-00123"/></div>
      <div class="field-row">
        <div class="field"><label>Mayor's Permit</label><input id="a-mayor" type="text" placeholder="MP-2024-00456"/></div>
        <div class="field"><label>TIN</label><input id="a-tin" type="text" placeholder="123-456-789"/></div>
      </div>
      <div class="sec-div">📸 Upload Documents</div>
      <div class="field"><label>Government-Issued ID *</label>
        <div class="upload-box"><input type="file" accept="image/*" onchange="previewFile(this,'prev-id')"/>
          <div>🪪</div><div style="font-size:13px;color:var(--muted);font-weight:600">Tap to upload Gov ID</div>
          <div class="upload-preview" id="prev-id"></div></div>
      </div>
      <div class="field"><label>Business Permit Photo</label>
        <div class="upload-box"><input type="file" accept="image/*" onchange="previewFile(this,'prev-permit')"/>
          <div>📄</div><div style="font-size:13px;color:var(--muted);font-weight:600">Tap to upload Permit</div>
          <div class="upload-preview" id="prev-permit"></div></div>
      </div>
      <div class="field"><label>Store Front Photo</label>
        <div class="upload-box"><input type="file" accept="image/*" onchange="previewFile(this,'prev-store')"/>
          <div>🏪</div><div style="font-size:13px;color:var(--muted);font-weight:600">Tap to upload Store Photo</div>
          <div class="upload-preview" id="prev-store"></div></div>
      </div>
      <button class="auth-btn" onclick="doApply()">📤 Submit Application</button>
    </div>
  </div>
</div>

<!-- PENDING -->
<div class="pending-screen" id="pendingScreen">
  <div class="pending-icon">⏳</div>
  <div class="pending-title">Application Submitted!</div>
  <div class="pending-sub">Your merchant application is being reviewed by the Admin. You will be notified once approved.</div>
  <div class="pending-badge">🔍 Under Review</div>
  <div class="logout-link" onclick="logout()">Log out</div>
</div>

<!-- MAIN APP -->
<div class="app" id="mainApp">
  <div class="header">
    <div class="header-top">
      <div class="brand">
        <div class="brand-icon">🏪</div>
        <div><div class="brand-name">Merchant Dashboard</div><div class="brand-sub" id="storeName">Palawan Delivery Express</div></div>
      </div>
      <div class="store-toggle">
        <span class="toggle-lbl" id="storeStatusLabel">Closed</span>
        <div class="toggle" id="storeToggle" onclick="toggleStore()"></div>
        <div style="background:rgba(255,255,255,.15);border:1.5px solid rgba(255,255,255,.3);border-radius:10px;padding:6px 10px;color:#fff;font-size:12px;font-weight:700;cursor:pointer;margin-left:8px" onclick="openNotif()">🔔</div>
      </div>
    </div>
  </div>

  <!-- DASHBOARD -->
  <div id="page-dashboard" class="page active">
    <div class="section-title">📊 Dashboard</div>
    <div class="stats-grid">
      <div class="stat-card" style="animation-delay:0ms"><div class="stat-icon">📦</div><div class="stat-val" id="s-total">0</div><div class="stat-label">Total Orders</div></div>
      <div class="stat-card red" style="animation-delay:60ms"><div class="stat-icon">⏳</div><div class="stat-val" id="s-pend">0</div><div class="stat-label">Pending</div></div>
      <div class="stat-card green" style="animation-delay:120ms"><div class="stat-icon">✅</div><div class="stat-val" id="s-acc">0</div><div class="stat-label">Accepted</div></div>
      <div class="stat-card gold" style="animation-delay:180ms"><div class="stat-icon">💰</div><div class="stat-val" id="s-rev">₱0</div><div class="stat-label">Revenue</div></div>
    </div>
    <!-- Sales mini chart -->
    <div class="sales-card">
      <h3>📈 This Week's Sales</h3>
      <div class="chart-bars" id="salesChart"></div>
    </div>
    <div class="section-title" style="padding-top:4px">🆕 New Orders <span id="newOrderCount" style="background:#ef4444;color:#fff;font-size:11px;font-weight:800;padding:2px 8px;border-radius:20px;margin-left:6px;display:none"></span></div>
    <div class="orders-wrap" id="new-orders-wrap">
      <div class="empty-state"><div class="ei">📭</div><p>No new orders yet</p></div>
    </div>
  </div>

  <!-- ALL ORDERS -->
  <div id="page-orders" class="page">
    <div class="section-title">📦 All Orders</div>
    <div class="filter-tabs">
      <div class="ftab active" onclick="filterOrders('all',this)">All</div>
      <div class="ftab" onclick="filterOrders('pending',this)">⏳ Pending</div>
      <div class="ftab" onclick="filterOrders('accepted',this)">✅ Accepted</div>
      <div class="ftab" onclick="filterOrders('ready',this)">📦 Ready</div>
      <div class="ftab" onclick="filterOrders('picked_up',this)">🛵 Transit</div>
      <div class="ftab" onclick="filterOrders('delivered',this)">🎉 Done</div>
    </div>
    <div class="orders-wrap" id="all-orders-wrap"><div class="spinner"></div></div>
  </div>

  <!-- ADD PRODUCT -->
  <div id="page-add" class="page">
    <div class="section-title" id="addFormTitle">➕ Post a Product</div>
    <div class="add-form">
      <h3>Product Details</h3>
      <div class="field"><label>Product Name *</label><input id="p-name" type="text" placeholder="e.g. Fresh Bangus 1kg"/></div>
      <div class="field-row">
        <div class="field"><label>Price (₱) *</label><input id="p-price" type="number" placeholder="120" min="1"/></div>
        <div class="field"><label>Stock *</label><input id="p-stock" type="number" placeholder="50" min="0"/></div>
      </div>
      <div class="field"><label>Category *</label>
        <select id="p-cat"><option value="">Select category</option>
          <option>Canned Goods</option><option>Rice & Grains</option><option>Meat & Poultry</option>
          <option>Fish & Seafood</option><option>Vegetables</option><option>Fruits</option>
          <option>Dairy & Eggs</option><option>Beverages</option><option>Bread & Bakery</option>
          <option>Noodles & Pasta</option><option>Condiments</option><option>Household</option>
          <option>Snacks</option><option>Cooking Oil</option><option>Baby Products</option><option>Health & Beauty</option>
        </select>
      </div>
      <div class="field"><label>Description</label><textarea id="p-desc" placeholder="Brief description of your product…"></textarea></div>
      <div class="field"><label>Product Image</label>
        <div class="upload-box"><input type="file" accept="image/*" id="p-img-input" onchange="previewProductImg(this)"/>
          <div id="p-img-preview" style="font-size:13px;color:var(--muted);font-weight:600">📸 Tap to upload product image</div>
        </div>
      </div>
      <input type="hidden" id="editing-product-id"/>
      <button class="submit-btn" onclick="saveProduct()" id="saveProductBtn">📤 Post Product</button>
      <button class="submit-btn" onclick="cancelEdit()" id="cancelEditBtn" style="display:none;background:#f3f4f6;color:var(--text);margin-top:8px">✕ Cancel Edit</button>
    </div>
  </div>

  <!-- MY PRODUCTS -->
  <div id="page-products" class="page">
    <div style="display:flex;align-items:center;justify-content:space-between;padding:18px 18px 10px">
      <div class="section-title" style="padding:0">🛍️ My Products</div>
      <div style="display:flex;gap:8px">
        <input id="prod-search" type="text" placeholder="Search…" oninput="searchProducts(this.value)" style="padding:8px 12px;border:1.5px solid var(--gl);border-radius:10px;font-size:13px;outline:none;font-family:inherit;width:120px"/>
      </div>
    </div>
    <div class="filter-tabs">
      <div class="ftab active" onclick="filterProducts('all',this)">All</div>
      <div class="ftab" onclick="filterProducts('available',this)">✅ Available</div>
      <div class="ftab" onclick="filterProducts('low',this)">⚠️ Low Stock</div>
      <div class="ftab" onclick="filterProducts('out',this)">❌ Out of Stock</div>
    </div>
    <div class="prod-list" id="prod-list"><div class="spinner"></div></div>
  </div>

  <!-- EARNINGS -->
  <div id="page-earnings" class="page">
    <div class="section-title">💰 Earnings</div>
    <div class="earn-card">
      <div class="earn-label">Total Earnings</div>
      <div class="earn-total" id="earn-total">₱0</div>
      <div class="earn-breakdown">
        <div class="earn-item"><div class="earn-val" id="earn-today">₱0</div><div class="earn-lbl">Today</div></div>
        <div class="earn-item"><div class="earn-val" id="earn-week">₱0</div><div class="earn-lbl">This Week</div></div>
        <div class="earn-item"><div class="earn-val" id="earn-cnt">0</div><div class="earn-lbl">Orders</div></div>
      </div>
    </div>
    <div class="section-title" style="padding-top:4px">📊 Top Products</div>
    <div class="prod-list" id="top-products-list"></div>
    <div class="section-title" style="padding-top:4px">✅ Completed Orders</div>
    <div class="orders-wrap" id="completed-orders-wrap">
      <div class="empty-state"><div class="ei">📊</div><p>No completed orders yet</p></div>
    </div>
  </div>

  <!-- PROFILE -->
  <div id="page-profile" class="page">
    <div class="profile-hero">
      <div class="store-avatar" onclick="document.getElementById('logoInput').click()">
        <span id="storeAvatarEmoji">🏪</span>
        <img id="storeAvatarImg" src="" style="display:none"/>
      </div>
      <div class="store-name-display" id="storeNameDisplay">My Store</div>
      <div class="store-sub" id="storeTypeDisplay">Merchant · PDE</div>
    </div>
    <input type="file" accept="image/*" class="avatar-input" id="logoInput" onchange="handleLogo(event)"/>
    <div class="profile-card">
      <div class="pf"><div class="pf-icon">👤</div><div class="pf-info"><div class="pf-label">Full Name</div><div class="pf-value" id="pf-name">—</div></div><div class="pf-edit" onclick="openEditProfile()">›</div></div>
      <div class="pf"><div class="pf-icon">📱</div><div class="pf-info"><div class="pf-label">Phone</div><div class="pf-value" id="pf-phone">—</div></div><div class="pf-edit" onclick="openEditProfile()">›</div></div>
      <div class="pf"><div class="pf-icon">✉️</div><div class="pf-info"><div class="pf-label">Email</div><div class="pf-value" id="pf-email">—</div></div></div>
      <div class="pf"><div class="pf-icon">📍</div><div class="pf-info"><div class="pf-label">Store Address</div><div class="pf-value" id="pf-addr">—</div></div><div class="pf-edit" onclick="openEditProfile()">›</div></div>
      <div class="pf"><div class="pf-icon">🏪</div><div class="pf-info"><div class="pf-label">Business Type</div><div class="pf-value" id="pf-btype">—</div></div></div>
      <div class="pf"><div class="pf-icon">📋</div><div class="pf-info"><div class="pf-label">DTI Number</div><div class="pf-value" id="pf-dti">—</div></div></div>
    </div>
    <div class="sec-title">Settings</div>
    <div class="menu-item" onclick="openEditProfile()"><div class="mi-icon">✏️</div><div class="mi-label">Edit Profile</div><div class="mi-arr">›</div></div>
    <div class="menu-item"><div class="mi-icon">🔒</div><div class="mi-label">Change Password</div><div class="mi-arr">›</div></div>
    <div class="menu-item" onclick="logout()"><div class="mi-icon">🚪</div><div class="mi-label" style="color:var(--red)">Log Out</div><div class="mi-arr">›</div></div>
    <div style="height:24px"></div>
  </div>

  <nav class="bottom-nav">
    <button class="nav-item active" onclick="showPage('dashboard',this)"><div class="nav-icon">📊</div><span class="nav-label">Dashboard</span><span class="n-badge" id="pendBadge"></span></button>
    <button class="nav-item" onclick="showPage('orders',this);renderAllOrders()"><div class="nav-icon">📦</div><span class="nav-label">Orders</span></button>
    <button class="nav-item" onclick="showPage('add',this)"><div class="nav-icon">➕</div><span class="nav-label">Add Product</span></button>
    <button class="nav-item" onclick="showPage('products',this);loadMyProducts()"><div class="nav-icon">🛍️</div><span class="nav-label">Products</span></button>
    <button class="nav-item" onclick="showPage('earnings',this);loadEarnings()"><div class="nav-icon">💰</div><span class="nav-label">Earnings</span></button>
    <button class="nav-item" onclick="showPage('profile',this)"><div class="nav-icon">👤</div><span class="nav-label">Profile</span></button>
  </nav>
</div>

<!-- EDIT PROFILE MODAL -->
<div class="modal-bg" id="editProfileModal" onclick="if(event.target===this)closeEditProfile()">
  <div class="modal-sheet">
    <div class="modal-handle"></div>
    <div class="modal-title">✏️ Edit Profile</div>
    <div class="field"><label>Full Name</label><input id="ep-name" type="text"/></div>
    <div class="field"><label>Phone Number</label><input id="ep-phone" type="tel"/></div>
    <div class="field"><label>Store Name</label><input id="ep-store" type="text"/></div>
    <div class="field"><label>Store Address</label><input id="ep-addr" type="text"/></div>
    <div class="field"><label>Store Description</label><textarea id="ep-desc" style="height:72px;width:100%;padding:12px 14px;border:1.5px solid #e5e7eb;border-radius:12px;font-family:inherit;font-size:14px;outline:none;resize:none"></textarea></div>
    <button class="modal-btn" onclick="saveProfile()">Save Changes</button>
  </div>
</div>

<!-- STOCK MODAL -->
<div class="modal-bg" id="stockModal" onclick="if(event.target===this)closeStockModal()">
  <div class="modal-sheet">
    <div class="modal-handle"></div>
    <div class="modal-title">📦 Update Stock</div>
    <div id="stock-product-name" style="font-size:15px;font-weight:700;color:var(--gd);margin-bottom:16px"></div>
    <div class="field"><label>New Stock Count</label><input id="stock-input" type="number" min="0" placeholder="0"/></div>
    <input type="hidden" id="stock-product-id"/>
    <button class="modal-btn" onclick="saveStock()">Update Stock</button>
  </div>
</div>

<!-- NOTIFICATIONS -->
<div class="side-panel" id="notifPanel">
  <div class="sp-header"><h3>🔔 Notifications</h3><span class="sp-close" onclick="closeNotif()">✕</span></div>
  <div id="notifList" style="padding:8px 0"><div class="notif-item"><div style="padding:20px;color:var(--muted);text-align:center;width:100%">No notifications yet</div></div></div>
</div>

<div class="toast" id="toastEl">✅ <span id="toastMsg"></span></div>

<script>
const API_URL = "https://pinaka-bagong-render-to-deliver.onrender.com";
const EM={rice:'🍚',vegetable:'🥦',fish:'🐟',isda:'🐟',meat:'🥩',chicken:'🍗',egg:'🥚',milk:'🥛',juice:'🧃',oil:'🫙',soap:'🧼',bread:'🍞',coffee:'☕',noodle:'🍜',canned:'🥫',sardine:'🥫',tuna:'🥫',chips:'🍿',beef:'🥩',pork:'🥩',bangus:'🐟',tilapia:'🐟',shrimp:'🦐',mango:'🥭',banana:'🍌'};
function emo(n){if(!n)return'📦';const l=n.toLowerCase();for(const[k,e]of Object.entries(EM))if(l.includes(k))return e;return'📦';}

let token=null,currentMerchant=null;
let allOrders=[],myProducts=[];
let currentOrderFilter='all',currentProdFilter='all';
let isStoreOpen=false;
let editingProductId=null;
let notifications=[];
let salesData=[0,0,0,0,0,0,0];

// ── SESSION ──
function checkSession(){
  const t=localStorage.getItem('pde_merch_token');
  const u=localStorage.getItem('pde_merch_user');
  if(t&&u){token=t;currentMerchant=JSON.parse(u);
    if(currentMerchant.status==='pending')showPending();
    else enterApp();}
}

function switchTab(tab){
  document.querySelectorAll('.auth-tab').forEach((t,i)=>t.classList.toggle('active',i===(tab==='login'?0:1)));
  document.querySelectorAll('.auth-form').forEach(f=>f.classList.remove('active'));
  document.getElementById('form-'+tab).classList.add('active');
}
function togglePw(id,btn){const i=document.getElementById(id);i.type=i.type==='password'?'text':'password';btn.textContent=i.type==='password'?'👁️':'🙈';}
function showErr(id,msg){const el=document.getElementById(id);el.textContent=msg;el.classList.add('show');setTimeout(()=>el.classList.remove('show'),4000);}
function previewFile(input,id){if(input.files&&input.files[0])document.getElementById(id).textContent='✅ '+input.files[0].name;}

async function doLogin(){
  const email=document.getElementById('l-email').value.trim();
  const pw=document.getElementById('l-pw').value;
  if(!email||!pw){showErr('login-err','Please fill in all fields.');return;}
  try{
    const r=await fetch(`${API}/merchants/login`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email,password:pw})});
    const d=await r.json();
    if(d.success&&d.token){token=d.token;currentMerchant=d.user;saveSession();enterApp();return;}
    if(d.status==='pending'){showErr('login-err','Your application is still pending approval.');return;}
    showErr('login-err',d.error||'Invalid credentials.');
  }catch(e){
    const db=JSON.parse(localStorage.getItem('pde_merchants_db')||'[]');
    const u=db.find(x=>x.email===email&&x.password===pw);
    if(!u){showErr('login-err','Account not found.');return;}
    if(u.status==='pending'){token='local_'+u.id;currentMerchant=u;saveSession();showPending();return;}
    if(u.status==='rejected'){showErr('login-err','Application was rejected. Contact admin.');return;}
    token='local_'+u.id;currentMerchant=u;saveSession();enterApp();
  }
}

async function doApply(){
  const name=document.getElementById('a-name').value.trim();
  const phone=document.getElementById('a-phone').value.trim();
  const email=document.getElementById('a-email').value.trim();
  const pw=document.getElementById('a-pw').value;
  const storeName=document.getElementById('a-store').value.trim();
  const btype=document.getElementById('a-btype').value;
  const addr=document.getElementById('a-addr').value.trim();
  const pcat=document.getElementById('a-pcat').value;
  const dti=document.getElementById('a-dti').value.trim();
  const permit=document.getElementById('a-permit').value.trim();
  if(!name||!phone||!email||!pw||!storeName||!btype||!addr||!pcat||!dti||!permit){showErr('apply-err','Please fill in all required (*) fields.');return;}
  if(pw.length<6){showErr('apply-err','Password must be at least 6 characters.');return;}
  const app={id:'merch_'+Date.now(),type:'merchant',name,phone,email,password:pw,storeName,businessType:btype,address:addr,productCategory:pcat,description:document.getElementById('a-desc').value.trim(),dtiNumber:dti,permitNumber:permit,mayorPermit:document.getElementById('a-mayor').value.trim(),tin:document.getElementById('a-tin').value.trim(),status:'pending',appliedAt:new Date().toISOString()};
  try{await fetch(`${API}/merchants/apply`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(app)});}catch(e){}
  const db=JSON.parse(localStorage.getItem('pde_merchants_db')||'[]');
  if(db.find(u=>u.email===email)){showErr('apply-err','Email already registered.');return;}
  db.push(app);localStorage.setItem('pde_merchants_db',JSON.stringify(db));
  const pending=JSON.parse(localStorage.getItem('pde_applications')||'[]');
  pending.unshift(app);localStorage.setItem('pde_applications',JSON.stringify(pending));
  document.getElementById('apply-ok').classList.add('show');
  token='local_'+app.id;currentMerchant=app;saveSession();
  setTimeout(()=>showPending(),2000);
}

function saveSession(){localStorage.setItem('pde_merch_token',token||'');localStorage.setItem('pde_merch_user',JSON.stringify(currentMerchant));}

function showPending(){
  document.getElementById('authScreen').style.display='none';
  document.getElementById('pendingScreen').classList.add('active');
}

function enterApp(){
  document.getElementById('authScreen').style.display='none';
  document.getElementById('pendingScreen').classList.remove('active');
  document.getElementById('mainApp').classList.add('active');
  updateStoreUI();loadDashboard();loadMyProducts();
  setInterval(loadDashboard,8000);
}

function logout(){
  token=null;currentMerchant=null;
  localStorage.removeItem('pde_merch_token');localStorage.removeItem('pde_merch_user');
  document.getElementById('mainApp').classList.remove('active');
  document.getElementById('pendingScreen').classList.remove('active');
  document.getElementById('authScreen').style.display='flex';
}

function updateStoreUI(){
  if(!currentMerchant)return;
  document.getElementById('storeName').textContent=currentMerchant.storeName||'My Store';
  document.getElementById('storeNameDisplay').textContent=currentMerchant.storeName||'My Store';
  document.getElementById('storeTypeDisplay').textContent=(currentMerchant.businessType||'Merchant')+' · PDE';
  document.getElementById('pf-name').textContent=currentMerchant.name||'—';
  document.getElementById('pf-phone').textContent=currentMerchant.phone||'—';
  document.getElementById('pf-email').textContent=currentMerchant.email||'—';
  document.getElementById('pf-addr').textContent=currentMerchant.address||'—';
  document.getElementById('pf-btype').textContent=currentMerchant.businessType||'—';
  document.getElementById('pf-dti').textContent=currentMerchant.dtiNumber||'—';
  isStoreOpen=currentMerchant.isOpen||false;
  updateStoreToggle();
}

function toggleStore(){
  isStoreOpen=!isStoreOpen;
  currentMerchant.isOpen=isStoreOpen;
  saveSession();updateStoreToggle();
  toast(isStoreOpen?'Store is now OPEN 🟢':'Store is now CLOSED 🔴');
  try{fetch(`${API}/merchants/toggle-store`,{method:'PUT',headers:{'Authorization':'Bearer '+token}});}catch(e){}
}
function updateStoreToggle(){
  const t=document.getElementById('storeToggle');
  const l=document.getElementById('storeStatusLabel');
  if(isStoreOpen){t.classList.add('on');l.textContent='Open';}
  else{t.classList.remove('on');l.textContent='Closed';}
}

// ── DASHBOARD ──
function showPage(page,btn){
  document.querySelectorAll('.page').forEach(p=>{p.classList.remove('active');p.style.display='';});
  document.getElementById('page-'+page).classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  if(btn)btn.classList.add('active');
}

async function loadDashboard(){
  try{
    const r=await fetch(`${API}/orders`,{headers:{'Authorization':'Bearer '+token}});
    const d=await r.json();
    allOrders=Array.isArray(d)?d:(d.orders||getSample());
  }catch{allOrders=getSample();}
  updateStats();renderNewOrders();renderSalesChart();
}

function getSample(){return[
  {id:'ORD-001',customerName:'Juan dela Cruz',customerAddress:'Brgy. San Jose',items:[{name:'Canned Sardines',qty:3,price:35},{name:'Rice 5kg',qty:1,price:280}],total:385,paymentMethod:'cod',status:'pending',date:'Jun 27, 2026'},
  {id:'ORD-002',customerName:'Maria Santos',customerAddress:'Brgy. Tiniguiban',items:[{name:'Fresh Bangus',qty:2,price:120}],total:240,paymentMethod:'gcash',status:'accepted',date:'Jun 27, 2026'},
];}

function updateStats(){
  const pend=allOrders.filter(o=>o.status==='pending').length;
  const acc=allOrders.filter(o=>['accepted','ready'].includes(o.status)).length;
  const rev=allOrders.filter(o=>o.status==='delivered').reduce((s,o)=>s+o.total,0);
  document.getElementById('s-total').textContent=allOrders.length;
  document.getElementById('s-pend').textContent=pend;
  document.getElementById('s-acc').textContent=acc;
  document.getElementById('s-rev').textContent='₱'+rev.toLocaleString();
  const pb=document.getElementById('pendBadge');
  if(pend>0){pb.style.display='flex';pb.textContent=pend;}else pb.style.display='none';
  const nc=document.getElementById('newOrderCount');
  if(pend>0){nc.style.display='inline';nc.textContent=pend;}else nc.style.display='none';
}

function renderSalesChart(){
  const days=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
  const vals=days.map((_,i)=>Math.floor(Math.random()*500+100));
  const max=Math.max(...vals);
  document.getElementById('salesChart').innerHTML=vals.map((v,i)=>`
    <div class="bar-wrap">
      <div class="bar-val">₱${v}</div>
      <div class="bar ${i===6?'highlight':''}" style="height:${Math.round(v/max*80)+10}px"></div>
      <div class="bar-day">${days[i]}</div>
    </div>`).join('');
}

function orderCard(o,i=0){
  const sm={pending:{l:'🆕 New Order',c:'s-new'},accepted:{l:'✅ Accepted',c:'s-acc'},ready:{l:'📦 Ready',c:'s-rdy'},picked_up:{l:'🛵 Picked Up',c:'s-done'},delivered:{l:'🎉 Delivered',c:'s-done'},rejected:{l:'❌ Rejected',c:'s-rej'}};
  const st=sm[o.status]||sm.pending;
  const payIcon={'cod':'💵','gcash':'📱','maya':'💜'}[o.paymentMethod]||'💵';
  let actions='';
  if(o.status==='pending')actions=`<div class="order-actions">
    <button class="btn-accept" onclick="acceptOrder('${o.id}',this)">✅ Accept</button>
    <button class="btn-reject" onclick="rejectOrder('${o.id}',this)">✕ Reject</button>
  </div>`;
  else if(o.status==='accepted')actions=`<div class="order-actions"><button class="btn-ready" onclick="markReady('${o.id}',this)">📦 Mark Ready for Pickup</button></div>`;
  else if(o.status==='ready')actions=`<div class="order-actions"><button class="btn-accept btn-off">⏳ Waiting for Rider…</button></div>`;
  else actions=`<div class="order-actions"><button class="btn-accept btn-off">${st.l}</button></div>`;
  return`<div class="order-card" style="animation-delay:${i*60}ms">
    <div class="order-hdr">
      <div><div class="order-id">${o.id}</div><div class="order-time">${o.date||''}</div></div>
      <div class="o-status ${st.c}">${st.l}</div>
    </div>
    <div class="order-customer">👤 ${o.customerName||'Customer'}</div>
    <div class="order-addr">📍 ${o.customerAddress||'—'}</div>
    <div class="order-items-list">${(o.items||[]).map(it=>`${emo(it.name||'')} ${it.name} ×${it.qty} — ₱${((it.price||0)*it.qty).toLocaleString()}`).join('<br>')}</div>
    <div class="order-pay">${payIcon} Payment: ${(o.paymentMethod||'cod').toUpperCase()}</div>
    <div class="order-total">Total: ₱${(o.total||0).toLocaleString()}</div>
    ${actions}
  </div>`;
}

function renderNewOrders(){
  const newO=allOrders.filter(o=>o.status==='pending');
  const el=document.getElementById('new-orders-wrap');
  el.innerHTML=newO.length?newO.map((o,i)=>orderCard(o,i)).join(''):`<div class="empty-state"><div class="ei">📭</div><p>No new orders</p></div>`;
}

function filterOrders(f,el){
  currentOrderFilter=f;
  document.querySelectorAll('#page-orders .ftab').forEach(t=>t.classList.remove('active'));el.classList.add('active');
  renderAllOrders();
}
function renderAllOrders(){
  const filtered=currentOrderFilter==='all'?allOrders:allOrders.filter(o=>o.status===currentOrderFilter);
  document.getElementById('all-orders-wrap').innerHTML=filtered.length?filtered.map((o,i)=>orderCard(o,i)).join(''):`<div class="empty-state"><div class="ei">📭</div><p>No orders here</p></div>`;
}

async function acceptOrder(id,btn){
  btn.classList.add('btn-off');btn.textContent='Accepting…';
  try{await fetch(`${API}/orders/${id}/status`,{method:'PATCH',headers:{'Content-Type':'application/json','Authorization':'Bearer '+token},body:JSON.stringify({status:'accepted'})});}catch(e){}
  const o=allOrders.find(x=>x.id===id||x._id===id);if(o)o.status='accepted';
  updateStats();renderNewOrders();renderAllOrders();
  addNotif('Order accepted! Customer notified ✅','📦');toast('Order accepted! Customer notified ✅');
}
async function rejectOrder(id,btn){
  btn.classList.add('btn-off');btn.textContent='Rejecting…';
  try{await fetch(`${API}/orders/${id}/status`,{method:'PATCH',headers:{'Content-Type':'application/json','Authorization':'Bearer '+token},body:JSON.stringify({status:'rejected'})});}catch(e){}
  allOrders=allOrders.filter(o=>o.id!==id&&o._id!==id);
  updateStats();renderNewOrders();renderAllOrders();toast('Order rejected.');
}
async function markReady(id,btn){
  btn.classList.add('btn-off');btn.textContent='Updating…';
  try{await fetch(`${API}/orders/${id}/status`,{method:'PATCH',headers:{'Content-Type':'application/json','Authorization':'Bearer '+token},body:JSON.stringify({status:'ready'})});}catch(e){}
  const o=allOrders.find(x=>x.id===id||x._id===id);if(o)o.status='ready';
  updateStats();renderNewOrders();renderAllOrders();
  addNotif('Order marked ready! Notifying riders 🛵','📦');toast('Order ready! Rider will be notified 🛵');
}

// ── PRODUCTS ──
function previewProductImg(input){
  if(input.files&&input.files[0]){
    const reader=new FileReader();
    reader.onload=e=>{document.getElementById('p-img-preview').innerHTML=`<img src="${e.target.result}" style="max-width:100%;max-height:80px;border-radius:8px;margin-top:8px"/>`;};
    reader.readAsDataURL(input.files[0]);
  }
}

async function saveProduct(){
  const name=document.getElementById('p-name').value.trim();
  const price=parseFloat(document.getElementById('p-price').value);
  const cat=document.getElementById('p-cat').value;
  const stock=parseInt(document.getElementById('p-stock').value)||0;
  const desc=document.getElementById('p-desc').value.trim();
  if(!name||!price||!cat){toast('Please fill in name, price and category');return;}
  const product={name,price,category:cat,description:desc,stock,merchantId:currentMerchant.id||currentMerchant._id,merchantName:currentMerchant.storeName||currentMerchant.name,isAvailable:stock>0};
  if(editingProductId){
    try{await fetch(`${API}/products/${editingProductId}`,{method:'PUT',headers:{'Content-Type':'application/json','Authorization':'Bearer '+token},body:JSON.stringify(product)});}catch(e){}
    const idx=myProducts.findIndex(p=>(p._id||p.id)===editingProductId);
    if(idx>-1)myProducts[idx]={...myProducts[idx],...product};
    toast(`"${name}" updated! ✅`);cancelEdit();
  }else{
    try{await fetch(`${API}/products`,{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+token},body:JSON.stringify(product)});}catch(e){}
    myProducts.unshift({...product,id:'p_'+Date.now()});
    toast(`"${name}" posted to Customer App! 🎉`);
  }
  ['p-name','p-price','p-desc','p-stock'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('p-cat').value='';
  document.getElementById('p-img-preview').innerHTML='📸 Tap to upload product image';
  renderMyProducts();
}

function editProduct(id){
  const p=myProducts.find(x=>(x._id||x.id)===id);
  if(!p)return;
  editingProductId=id;
  document.getElementById('p-name').value=p.name||'';
  document.getElementById('p-price').value=p.price||'';
  document.getElementById('p-cat').value=p.category||'';
  document.getElementById('p-stock').value=p.stock||0;
  document.getElementById('p-desc').value=p.description||'';
  document.getElementById('addFormTitle').textContent='✏️ Edit Product';
  document.getElementById('saveProductBtn').textContent='💾 Save Changes';
  document.getElementById('cancelEditBtn').style.display='block';
  showPage('add',document.querySelectorAll('.nav-item')[2]);
}

function cancelEdit(){
  editingProductId=null;
  document.getElementById('addFormTitle').textContent='➕ Post a Product';
  document.getElementById('saveProductBtn').textContent='📤 Post Product';
  document.getElementById('cancelEditBtn').style.display='none';
  ['p-name','p-price','p-desc','p-stock'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('p-cat').value='';
}

async function loadMyProducts(){
  try{
    const r=await fetch(`${API}/products?merchantId=${currentMerchant.id||currentMerchant._id}`,{headers:{'Authorization':'Bearer '+token}});
    const d=await r.json();
    myProducts=Array.isArray(d)?d:(d.products||[]);
  }catch{myProducts=[];}
  renderMyProducts();
}

function filterProducts(f,el){
  currentProdFilter=f;
  document.querySelectorAll('#page-products .ftab').forEach(t=>t.classList.remove('active'));el.classList.add('active');
  renderMyProducts();
}

function searchProducts(q){
  renderMyProducts(q);
}

function renderMyProducts(search=''){
  let prods=myProducts;
  if(search)prods=prods.filter(p=>p.name.toLowerCase().includes(search.toLowerCase()));
  if(currentProdFilter==='available')prods=prods.filter(p=>p.stock>5&&p.isAvailable!==false);
  else if(currentProdFilter==='low')prods=prods.filter(p=>p.stock>0&&p.stock<=5);
  else if(currentProdFilter==='out')prods=prods.filter(p=>p.stock===0||p.isAvailable===false);
  const el=document.getElementById('prod-list');
  if(!prods.length){el.innerHTML=`<div class="empty-state"><div class="ei">🛍️</div><p>No products found</p></div>`;return;}
  el.innerHTML=prods.map((p,i)=>{
    const id=p._id||p.id;
    const stockCls=p.stock===0?'stock-out':p.stock<=5?'stock-low':'stock-ok';
    const stockLabel=p.stock===0?'❌ Out of Stock':p.stock<=5?`⚠️ Low Stock (${p.stock})`:`✅ In Stock (${p.stock})`;
    return`<div class="prod-item" style="animation-delay:${i*50}ms">
      <div class="prod-item-top">
        <div class="prod-img">${p.image?`<img src="${p.image}" onerror="this.style.display='none'"/>`:emo(p.name)}</div>
        <div class="prod-info">
          <div class="prod-name">${p.name}</div>
          <div class="prod-price">₱${Number(p.price).toLocaleString()}</div>
          <div class="prod-cat">${p.category||''}</div>
          <div class="stock-badge ${stockCls}">${stockLabel}</div>
        </div>
      </div>
      <div class="prod-actions">
        <button class="prod-btn btn-edit-prod" onclick="editProduct('${id}')">✏️ Edit</button>
        <button class="prod-btn btn-toggle-stock" onclick="openStockModal('${id}','${p.name}',${p.stock||0})">📦 Stock</button>
        <button class="prod-btn btn-del-prod" onclick="deleteProduct('${id}',this)">🗑️</button>
      </div>
    </div>`;
  }).join('');
}

function openStockModal(id,name,stock){
  document.getElementById('stock-product-id').value=id;
  document.getElementById('stock-product-name').textContent=`📦 ${name}`;
  document.getElementById('stock-input').value=stock;
  document.getElementById('stockModal').classList.add('open');
}
function closeStockModal(){document.getElementById('stockModal').classList.remove('open');}
async function saveStock(){
  const id=document.getElementById('stock-product-id').value;
  const stock=parseInt(document.getElementById('stock-input').value)||0;
  try{await fetch(`${API}/products/${id}/stock`,{method:'PUT',headers:{'Content-Type':'application/json','Authorization':'Bearer '+token},body:JSON.stringify({stock})});}catch(e){}
  const p=myProducts.find(x=>(x._id||x.id)===id);
  if(p){p.stock=stock;p.isAvailable=stock>0;}
  closeStockModal();renderMyProducts();toast(`Stock updated to ${stock} ✅`);
}

async function deleteProduct(id,btn){
  btn.textContent='…';
  try{await fetch(`${API}/products/${id}`,{method:'DELETE',headers:{'Authorization':'Bearer '+token}});}catch(e){}
  myProducts=myProducts.filter(p=>(p._id||p.id)!==id);
  renderMyProducts();toast('Product removed.');
}

// ── EARNINGS ──
function loadEarnings(){
  const done=allOrders.filter(o=>o.status==='delivered');
  const total=done.reduce((s,o)=>s+o.total,0);
  document.getElementById('earn-total').textContent='₱'+total.toLocaleString();
  document.getElementById('earn-today').textContent='₱'+total.toLocaleString();
  document.getElementById('earn-week').textContent='₱'+total.toLocaleString();
  document.getElementById('earn-cnt').textContent=done.length;
  // Top products
  const prodSales={};
  done.forEach(o=>(o.items||[]).forEach(it=>{if(!prodSales[it.name])prodSales[it.name]={name:it.name,qty:0,rev:0};prodSales[it.name].qty+=it.qty;prodSales[it.name].rev+=it.price*it.qty;}));
  const top=Object.values(prodSales).sort((a,b)=>b.rev-a.rev).slice(0,5);
  document.getElementById('top-products-list').innerHTML=top.length?top.map((p,i)=>`<div class="prod-item">
    <div class="prod-item-top">
      <div class="prod-img">${emo(p.name)}</div>
      <div class="prod-info"><div class="prod-name">${p.name}</div><div class="prod-price">₱${p.rev.toLocaleString()}</div><div class="prod-cat">${p.qty} units sold</div></div>
      <div style="font-size:20px;font-weight:800;color:var(--muted)">#${i+1}</div>
    </div></div>`).join(''):`<div class="empty-state"><div class="ei">📊</div><p>No sales data yet</p></div>`;
  document.getElementById('completed-orders-wrap').innerHTML=done.length?done.map((o,i)=>orderCard(o,i)).join(''):`<div class="empty-state"><div class="ei">📊</div><p>No completed orders yet</p></div>`;
}

// ── PROFILE ──
function openEditProfile(){
  document.getElementById('ep-name').value=currentMerchant.name||'';
  document.getElementById('ep-phone').value=currentMerchant.phone||'';
  document.getElementById('ep-store').value=currentMerchant.storeName||'';
  document.getElementById('ep-addr').value=currentMerchant.address||'';
  document.getElementById('ep-desc').value=currentMerchant.description||'';
  document.getElementById('editProfileModal').classList.add('open');
}
function closeEditProfile(){document.getElementById('editProfileModal').classList.remove('open');}
async function saveProfile(){
  const name=document.getElementById('ep-name').value.trim();
  const phone=document.getElementById('ep-phone').value.trim();
  const storeName=document.getElementById('ep-store').value.trim();
  const address=document.getElementById('ep-addr').value.trim();
  const description=document.getElementById('ep-desc').value.trim();
  currentMerchant={...currentMerchant,name,phone,storeName,address,description};
  saveSession();updateStoreUI();
  try{await fetch(`${API}/merchants/me`,{method:'PUT',headers:{'Content-Type':'application/json','Authorization':'Bearer '+token},body:JSON.stringify({name,phone,storeName,address,description})});}catch(e){}
  closeEditProfile();toast('Profile updated!');
}

function handleLogo(e){
  const f=e.target.files[0];if(!f)return;
  const r=new FileReader();
  r.onload=ev=>{const img=document.getElementById('storeAvatarImg');img.src=ev.target.result;img.style.display='block';document.getElementById('storeAvatarEmoji').style.display='none';toast('Store logo updated!');};
  r.readAsDataURL(f);
}

// ── NOTIFICATIONS ──
function addNotif(text,emoji){
  notifications.unshift({text,emoji,time:'Just now',unread:true});
  renderNotifs();
}
function renderNotifs(){
  const el=document.getElementById('notifList');
  if(!notifications.length){el.innerHTML=`<div class="notif-item"><div style="padding:20px;color:var(--muted);text-align:center;width:100%">No notifications yet</div></div>`;return;}
  el.innerHTML=notifications.map(n=>`<div class="notif-item ${n.unread?'unread':''}">
    <span style="font-size:20px">${n.emoji}</span>
    <div><div class="ni-text">${n.text}</div><div class="ni-time">${n.time}</div></div></div>`).join('');
}
function openNotif(){document.getElementById('notifPanel').classList.add('open');notifications.forEach(n=>n.unread=false);renderNotifs();}
function closeNotif(){document.getElementById('notifPanel').classList.remove('open');}

function toast(msg){const t=document.getElementById('toastEl');document.getElementById('toastMsg').textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2800);}

checkSession();
</script>
</body>
</html>
